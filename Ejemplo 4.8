import java.util.Scanner;

public class CuadradoYCubo {

    public static void main(String[] args) {

        Scanner leer = new Scanner(System.in);

        int n, m, cuadrados = 0, cubos = 0;

        System.out.print("m: ");
        m = leer.nextInt();

        System.out.print("n: ");
        n = leer.nextInt();

        System.out.println();

        while (m <= n) {

            // verificar si es cuadrado perfecto
            if (m == Math.pow((int) Math.pow(m, 1 / 2.0), 2)) {

                System.out.println(m + " es cuadrado");
                cuadrados++;
            }

            // verificar si es cubo perfecto
            if (m == Math.pow((int) Math.pow(m, 1 / 3.0), 3)) {

                System.out.println(m + " es cubo");
                cubos++;
            }

            m++;
        }

        System.out.println("\nTotal cuadrados = " + cuadrados);
        System.out.println("Total cubos = " + cubos);

        leer.close();
    }
}
